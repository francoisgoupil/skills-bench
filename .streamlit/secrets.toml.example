# Copy to `.streamlit/secrets.toml` for local Streamlit, or paste these keys in
# Streamlit Community Cloud → App settings → Secrets.
#
# The dashboard only needs Skore Hub credentials (no LLM API keys).

SKORE_WORKSPACE = "your-workspace-name"
SKORE_HUB_API_KEY = "your-skore-hub-api-key"
SKORE_HUB_URI = "https://api.skore.probabl.ai"

# Optional: path to the local cost sidecar (defaults to bundled data/runs.public.db)
# BENCH_COST_DB = "data/runs.public.db"
